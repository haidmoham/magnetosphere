# Flask
FLASK_SECRET_KEY=change-me

# App
APP_VERSION=1.0.0

# Spotify OAuth — leave blank to disable the Spotify source.
# Create an app at https://developer.spotify.com/dashboard, then add
# the redirect URI below to its "Redirect URIs" list.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/auth/spotify/callback
